<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>MBA ROI Calculator</title>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg-primary: #ffffff;
      --bg-secondary: #f5f5f3;
      --bg-tertiary: #eeede8;
      --bg-success: #e1f5ee;
      --bg-warning: #faeeda;
      --bg-danger: #fcebeb;
      --text-primary: #1a1a1a;
      --text-secondary: #555;
      --text-tertiary: #999;
      --text-success: #0f6e56;
      --text-warning: #854f0b;
      --text-danger: #a32d2d;
      --border: rgba(0,0,0,0.12);
      --border-secondary: rgba(0,0,0,0.22);
      --radius-md: 8px;
      --radius-lg: 12px;
      --teal: #1D9E75;
      --blue: #378ADD;
      --amber: #EF9F27;
      --red: #E24B4A;
    }

    @media (prefers-color-scheme: dark) {
      :root {
        --bg-primary: #1e1e1e;
        --bg-secondary: #2a2a2a;
        --bg-tertiary: #141414;
        --bg-success: #0a2e22;
        --bg-warning: #2e1f04;
        --bg-danger: #2e0a0a;
        --text-primary: #f0eeea;
        --text-secondary: #aaa;
        --text-tertiary: #666;
        --text-success: #5DCAA5;
        --text-warning: #FAC775;
        --text-danger: #F09595;
        --border: rgba(255,255,255,0.1);
        --border-secondary: rgba(255,255,255,0.2);
      }
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: var(--bg-tertiary);
      color: var(--text-primary);
      min-height: 100vh;
      padding: 2rem 1rem 4rem;
    }

    .page-header {
      max-width: 640px;
      margin: 0 auto 2rem;
    }
    .page-header h1 {
      font-size: 26px;
      font-weight: 500;
      color: var(--text-primary);
      margin-bottom: 6px;
    }
    .page-header p {
      font-size: 14px;
      color: var(--text-secondary);
      line-height: 1.6;
    }

    .wrap { max-width: 640px; margin: 0 auto; display: flex; flex-direction: column; gap: 0; }

    .sec-label {
      font-size: 11px; font-weight: 500; letter-spacing: 0.07em;
      text-transform: uppercase; color: var(--text-tertiary);
      margin: 1.5rem 0 0.65rem;
    }

    .card {
      background: var(--bg-primary);
      border: 0.5px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 1.1rem 1.25rem;
      display: flex; flex-direction: column; gap: 16px;
    }

    .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    @media (max-width: 480px) { .two-col { grid-template-columns: 1fr; } }

    .field { display: flex; flex-direction: column; gap: 5px; }
    .field label { font-size: 13px; color: var(--text-secondary); }

    input[type="number"] {
      width: 100%;
      height: 36px;
      padding: 0 10px;
      border: 0.5px solid var(--border-secondary);
      border-radius: var(--radius-md);
      background: var(--bg-primary);
      color: var(--text-primary);
      font-size: 14px;
      outline: none;
      transition: border-color 0.15s;
    }
    input[type="number"]:focus { border-color: var(--teal); box-shadow: 0 0 0 2px rgba(29,158,117,0.15); }

    input[type="range"] {
      flex: 1;
      height: 4px;
      accent-color: var(--teal);
      cursor: pointer;
    }

    .slider-row { display: flex; align-items: center; gap: 10px; }
    .slider-val { font-size: 14px; font-weight: 500; min-width: 22px; text-align: right; color: var(--text-primary); }
    .slider-ends { display: flex; justify-content: space-between; font-size: 11px; color: var(--text-tertiary); margin-top: 3px; }

    .calc-btn {
      width: 100%; margin-top: 1.5rem; padding: 12px;
      font-size: 15px; font-weight: 500;
      background: var(--teal); color: #fff;
      border: none; border-radius: var(--radius-md);
      cursor: pointer; transition: opacity 0.15s, transform 0.1s;
      letter-spacing: 0.01em;
    }
    .calc-btn:hover { opacity: 0.88; }
    .calc-btn:active { transform: scale(0.98); }

    .results { margin-top: 2rem; display: none; flex-direction: column; gap: 1.25rem; }
    .results.show { display: flex; }

    .metric-grid { display: grid; grid-template-columns: repeat(4, minmax(0,1fr)); gap: 10px; }
    @media (max-width: 500px) { .metric-grid { grid-template-columns: repeat(2, minmax(0,1fr)); } }

    .metric {
      background: var(--bg-secondary);
      border-radius: var(--radius-md);
      padding: 0.9rem 1rem;
    }
    .metric-label { font-size: 12px; color: var(--text-tertiary); margin-bottom: 4px; }
    .metric-val { font-size: 20px; font-weight: 500; color: var(--text-primary); }
    .metric-sub { font-size: 11px; color: var(--text-tertiary); margin-top: 3px; }

    .fit-card {
      background: var(--bg-primary);
      border: 0.5px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 1.1rem 1.25rem;
    }
    .fit-header { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 12px; }
    .fit-title { font-size: 14px; font-weight: 500; color: var(--text-primary); }
    .fit-score { font-size: 26px; font-weight: 500; color: var(--text-primary); }
    .fit-bar-wrap { height: 6px; background: var(--bg-secondary); border-radius: 3px; overflow: hidden; margin-bottom: 10px; }
    .fit-bar { height: 100%; border-radius: 3px; transition: width 0.5s ease; }
    .fit-breakdown { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; }
    .fit-item { font-size: 12px; color: var(--text-secondary); display: flex; justify-content: space-between; }

    .verdict-card { border-radius: var(--radius-lg); padding: 1.2rem 1.25rem; }
    .verdict-card.green { background: var(--bg-success); border: 0.5px solid #5DCAA5; }
    .verdict-card.yellow { background: var(--bg-warning); border: 0.5px solid #EF9F27; }
    .verdict-card.red { background: var(--bg-danger); border: 0.5px solid #F09595; }
    .verdict-label { font-size: 11px; font-weight: 500; letter-spacing: 0.07em; text-transform: uppercase; margin-bottom: 5px; }
    .verdict-card.green .verdict-label { color: #0F6E56; }
    .verdict-card.yellow .verdict-label { color: #854F0B; }
    .verdict-card.red .verdict-label { color: #A32D2D; }
    .verdict-title { font-size: 20px; font-weight: 500; margin-bottom: 7px; }
    .verdict-card.green .verdict-title { color: #085041; }
    .verdict-card.yellow .verdict-title { color: #633806; }
    .verdict-card.red .verdict-title { color: #791F1F; }
    .verdict-body { font-size: 13px; line-height: 1.65; }
    .verdict-card.green .verdict-body { color: #0F6E56; }
    .verdict-card.yellow .verdict-body { color: #854F0B; }
    .verdict-card.red .verdict-body { color: #A32D2D; }

    .chart-card {
      background: var(--bg-primary);
      border: 0.5px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 1.1rem 1.25rem;
    }
    .chart-legend { display: flex; gap: 16px; margin-bottom: 12px; font-size: 12px; color: var(--text-secondary); flex-wrap: wrap; }
    .legend-dot { width: 10px; height: 10px; border-radius: 2px; flex-shrink: 0; margin-top: 1px; }

    .cashflow-table { width: 100%; border-collapse: collapse; font-size: 12px; }
    .cashflow-table th {
      font-weight: 500; color: var(--text-tertiary);
      text-align: left; padding: 8px 10px;
      border-bottom: 0.5px solid var(--border);
      font-size: 11px; text-transform: uppercase; letter-spacing: 0.05em;
      background: var(--bg-secondary);
    }
    .cashflow-table td { padding: 6px 10px; color: var(--text-secondary); border-bottom: 0.5px solid var(--border); }
    .cashflow-table tr:last-child td { border-bottom: none; }
    .cashflow-table td.pos { color: #0F6E56; }
    .cashflow-table td.neg { color: #A32D2D; }
    .cashflow-table td.num { text-align: right; font-variant-numeric: tabular-nums; }
    .cashflow-table tr:hover td { background: var(--bg-secondary); }

    footer {
      max-width: 640px;
      margin: 2rem auto 0;
      font-size: 12px;
      color: var(--text-tertiary);
      text-align: center;
      line-height: 1.6;
    }
  </style>
</head>
<body>

<div class="page-header">
  <h1>MBA ROI calculator</h1>
  <p>Model the financial and personal return on an MBA — including NPV, payback period, salary projections, and a personal fit score.</p>
</div>

<div class="wrap">

  <p class="sec-label">Financial inputs</p>
  <div class="card">
    <div class="two-col">
      <div class="field"><label for="cur-sal">Current salary ($)</label><input type="number" id="cur-sal" value="90000" step="1000" min="0"></div>
      <div class="field"><label for="post-sal">Post-MBA salary ($)</label><input type="number" id="post-sal" value="150000" step="1000" min="0"></div>
    </div>
    <div class="field"><label for="tuition">Total tuition cost ($)</label><input type="number" id="tuition" value="200000" step="1000" min="0"></div>
    <div class="two-col">
      <div class="field"><label for="mba-yrs">MBA duration (years)</label><input type="number" id="mba-yrs" value="2" min="1" max="4" step="1"></div>
      <div class="field"><label for="growth">Salary growth rate (%)</label><input type="number" id="growth" value="5" min="0" max="30" step="0.5"></div>
    </div>
    <div class="field"><label for="discount">Discount rate (%)</label><input type="number" id="discount" value="7" min="0" max="30" step="0.5"></div>
  </div>

  <p class="sec-label">Personal factors</p>
  <div class="card">
    <div class="field">
      <label>Prestige value <span style="font-size:11px;color:var(--text-tertiary);">(weight: 20%)</span></label>
      <div class="slider-row"><input type="range" id="prestige" min="1" max="10" step="1" value="6" oninput="sv('prestige-v',this.value)"><span class="slider-val" id="prestige-v">6</span></div>
      <div class="slider-ends"><span>Not important</span><span>Very important</span></div>
    </div>
    <div class="field">
      <label>Emotional investment <span style="font-size:11px;color:var(--text-tertiary);">(weight: 30%)</span></label>
      <div class="slider-row"><input type="range" id="emotional" min="1" max="10" step="1" value="7" oninput="sv('emotional-v',this.value)"><span class="slider-val" id="emotional-v">7</span></div>
      <div class="slider-ends"><span>Low</span><span>High</span></div>
    </div>
    <div class="field">
      <label>Career stage <span style="font-size:11px;color:var(--text-tertiary);">(weight: 25% — earlier = better ROI)</span></label>
      <div class="slider-row"><input type="range" id="career" min="1" max="10" step="1" value="4" oninput="sv('career-v',this.value)"><span class="slider-val" id="career-v">4</span></div>
      <div class="slider-ends"><span>Early career</span><span>Senior</span></div>
    </div>
    <div class="field">
      <label>Current job stress <span style="font-size:11px;color:var(--text-tertiary);">(weight: 25% — higher stress = stronger push)</span></label>
      <div class="slider-row"><input type="range" id="stress" min="1" max="10" step="1" value="6" oninput="sv('stress-v',this.value)"><span class="slider-val" id="stress-v">6</span></div>
      <div class="slider-ends"><span>Low stress</span><span>Burnout</span></div>
    </div>
  </div>

  <button class="calc-btn" onclick="calculate()">Calculate ROI</button>

  <div class="results" id="results">

    <div>
      <p class="sec-label" style="margin-top:0.5rem;">Financial summary</p>
      <div class="metric-grid">
        <div class="metric"><div class="metric-label">10-yr NPV</div><div class="metric-val" id="r-npv">—</div><div class="metric-sub">discounted gain</div></div>
        <div class="metric"><div class="metric-label">Payback period</div><div class="metric-val" id="r-payback">—</div><div class="metric-sub">years to break even</div></div>
        <div class="metric"><div class="metric-label">Total with MBA</div><div class="metric-val" id="r-with">—</div><div class="metric-sub">cumulative 10 yr</div></div>
        <div class="metric"><div class="metric-label">Total w/o MBA</div><div class="metric-val" id="r-without">—</div><div class="metric-sub">cumulative 10 yr</div></div>
      </div>
    </div>

    <div class="fit-card">
      <div class="fit-header">
        <span class="fit-title">MBA fit score</span>
        <span class="fit-score" id="fit-score-val">—</span>
      </div>
      <div class="fit-bar-wrap"><div class="fit-bar" id="fit-bar" style="width:0%;background:#1D9E75;"></div></div>
      <div class="fit-breakdown" id="fit-breakdown"></div>
    </div>

    <div class="verdict-card" id="verdict-card">
      <div class="verdict-label" id="verdict-label">Recommendation</div>
      <div class="verdict-title" id="verdict-title">—</div>
      <div class="verdict-body" id="verdict-body">—</div>
    </div>

    <div class="chart-card">
      <div class="chart-legend">
        <span style="display:flex;align-items:center;gap:5px;"><span class="legend-dot" style="background:#1D9E75;"></span>With MBA (cumulative)</span>
        <span style="display:flex;align-items:center;gap:5px;"><span class="legend-dot" style="background:#378ADD;border:1.5px dashed #378ADD;background:transparent;width:18px;height:0;border-top:2px dashed #378ADD;border-radius:0;margin-top:5px;"></span>Without MBA (cumulative)</span>
      </div>
      <div style="position:relative;width:100%;height:280px;">
        <canvas id="salary-chart" role="img" aria-label="Line chart comparing cumulative salary with MBA vs without MBA over 10 years">Salary comparison chart loading...</canvas>
      </div>
    </div>

    <div>
      <p class="sec-label" style="margin-top:0.25rem;">Annual cash flow breakdown</p>
      <div style="background:var(--bg-primary);border:0.5px solid var(--border);border-radius:var(--radius-lg);overflow:hidden;">
        <table class="cashflow-table">
          <thead>
            <tr>
              <th>Year</th>
              <th class="num">W/o MBA ($)</th>
              <th class="num">With MBA ($)</th>
              <th class="num">Difference ($)</th>
              <th class="num">Disc. CF ($)</th>
            </tr>
          </thead>
          <tbody id="cf-tbody"></tbody>
        </table>
      </div>
    </div>

  </div>
</div>

<footer>
  Built with HTML, CSS &amp; JavaScript &mdash; no server required.<br>
  Assumptions: 10-year horizon, salary grows at a constant rate, tuition is spread evenly across MBA years.
</footer>

<script>
  let salaryChart = null;

  function sv(id, val) { document.getElementById(id).textContent = val; }

  function fmt(n) {
    const abs = Math.abs(n);
    const sign = n < 0 ? '-' : '';
    if (abs >= 1e6) return sign + '$' + (abs / 1e6).toFixed(2) + 'M';
    if (abs >= 1e3) return sign + '$' + Math.round(abs / 1e3) + 'K';
    return sign + '$' + Math.round(abs);
  }

  function calculate() {
    const curSal   = parseFloat(document.getElementById('cur-sal').value)  || 0;
    const postSal  = parseFloat(document.getElementById('post-sal').value) || 0;
    const tuition  = parseFloat(document.getElementById('tuition').value)  || 0;
    const mbaYrs   = parseInt(document.getElementById('mba-yrs').value)    || 2;
    const growth   = parseFloat(document.getElementById('growth').value)   / 100;
    const discount = parseFloat(document.getElementById('discount').value) / 100;
    const prestige = parseInt(document.getElementById('prestige').value);
    const emotional= parseInt(document.getElementById('emotional').value);
    const career   = parseInt(document.getElementById('career').value);
    const stress   = parseInt(document.getElementById('stress').value);

    const years = 10;
    const woSals = [], wSals = [], diffs = [], discCFs = [];
    let cumWo = 0, cumW = 0, npv = 0;
    let payback = null;
    let cumDiff = -(tuition + curSal * mbaYrs);

    for (let y = 1; y <= years; y++) {
      const woSal = curSal * Math.pow(1 + growth, y);
      woSals.push(woSal);
      cumWo += woSal;

      let wSal, diff;
      if (y <= mbaYrs) {
        wSal = -(tuition / mbaYrs);
        diff = wSal - woSal;
      } else {
        wSal = postSal * Math.pow(1 + growth, y - mbaYrs);
        diff = wSal - woSal;
      }
      wSals.push(Math.max(wSal, 0));
      cumW += Math.max(wSal, 0);
      diffs.push(diff);

      const dcf = diff / Math.pow(1 + discount, y);
      discCFs.push(dcf);
      npv += dcf;

      if (payback === null) {
        cumDiff += diff;
        if (cumDiff >= 0) payback = y;
      }
    }

    document.getElementById('r-npv').textContent     = fmt(npv);
    document.getElementById('r-payback').textContent = payback ? payback + ' yrs' : '>10 yrs';
    document.getElementById('r-with').textContent    = fmt(cumW);
    document.getElementById('r-without').textContent = fmt(cumWo);

    const fitScore = calcFitScore(prestige, emotional, career, stress);
    renderFitScore(fitScore, prestige, emotional, career, stress);
    renderVerdict(npv, fitScore);
    renderChart(woSals, wSals, years);
    renderTable(woSals, wSals, diffs, discCFs, mbaYrs);

    document.getElementById('results').classList.add('show');
    document.getElementById('results').scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  function calcFitScore(prestige, emotional, career, stress) {
    const careerFit = 11 - career;
    return prestige * 0.20 + emotional * 0.30 + careerFit * 0.25 + stress * 0.25;
  }

  function renderFitScore(score, prestige, emotional, career, stress) {
    const pct = Math.round((score / 10) * 100);
    document.getElementById('fit-score-val').textContent = score.toFixed(1) + ' / 10';
    const bar = document.getElementById('fit-bar');
    bar.style.width = pct + '%';
    bar.style.background = score >= 7 ? '#1D9E75' : score >= 5 ? '#EF9F27' : '#E24B4A';

    document.getElementById('fit-breakdown').innerHTML = `
      <span class="fit-item"><span>Prestige (20%)</span><span>${prestige} / 10</span></span>
      <span class="fit-item"><span>Emotional (30%)</span><span>${emotional} / 10</span></span>
      <span class="fit-item"><span>Career timing (25%)</span><span>${11 - career} / 10</span></span>
      <span class="fit-item"><span>Job stress (25%)</span><span>${stress} / 10</span></span>
    `;
  }

  function renderVerdict(npv, fitScore) {
    const vc = document.getElementById('verdict-card');
    const vt = document.getElementById('verdict-title');
    const vb = document.getElementById('verdict-body');
    vc.className = 'verdict-card';

    const npvPos  = npv > 0;
    const fitGood = fitScore >= 6;

    if (npvPos && fitGood) {
      vc.classList.add('green');
      vt.textContent = 'Strong yes';
      vb.textContent = 'The financials are positive and your personal fit is strong. This MBA looks like a solid investment on both dimensions — move forward with confidence.';
    } else if (npvPos || fitGood) {
      vc.classList.add('yellow');
      vt.textContent = 'Depends';
      vb.textContent = npvPos
        ? 'The financial return is there, but your personal fit score is moderate. Weigh the opportunity cost carefully — timing and motivation matter as much as money.'
        : 'Your personal drivers are strong, but the financial return is unclear. Consider part-time or employer-sponsored programs to improve the NPV.';
    } else {
      vc.classList.add('red');
      vt.textContent = 'Not worth it';
      vb.textContent = 'Neither the financials nor the personal fit score support this decision right now. Reconsider the timing, program cost, or whether an MBA is the right lever for your goals.';
    }
  }

  function renderChart(woSals, wSals, years) {
    const labels = Array.from({ length: years }, (_, i) => 'Yr ' + (i + 1));
    let cumWo = 0, cumW = 0;
    const cumWoData = woSals.map(s => { cumWo += s; return Math.round(cumWo); });
    const cumWData  = wSals.map(s  => { cumW  += s; return Math.round(cumW);  });

    if (salaryChart) salaryChart.destroy();

    salaryChart = new Chart(document.getElementById('salary-chart'), {
      type: 'line',
      data: {
        labels,
        datasets: [
          {
            label: 'With MBA',
            data: cumWData,
            borderColor: '#1D9E75',
            borderWidth: 2.5,
            pointRadius: 3,
            pointBackgroundColor: '#1D9E75',
            tension: 0.3,
            fill: false,
            borderDash: []
          },
          {
            label: 'Without MBA',
            data: cumWoData,
            borderColor: '#378ADD',
            borderWidth: 2.5,
            pointRadius: 3,
            pointBackgroundColor: '#378ADD',
            tension: 0.3,
            fill: false,
            borderDash: [6, 4]
          }
        ]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: ctx => ctx.dataset.label + ': ' + fmt(ctx.parsed.y)
            }
          }
        },
        scales: {
          x: {
            grid: { color: 'rgba(128,128,128,0.1)' },
            ticks: { font: { size: 11 }, autoSkip: false, maxRotation: 0 }
          },
          y: {
            grid: { color: 'rgba(128,128,128,0.1)' },
            ticks: { font: { size: 11 }, callback: v => fmt(v) }
          }
        }
      }
    });
  }

  function renderTable(woSals, wSals, diffs, discCFs, mbaYrs) {
    document.getElementById('cf-tbody').innerHTML = woSals.map((_, i) => {
      const diff = diffs[i];
      const dcf  = discCFs[i];
      const inProgram = i + 1 <= mbaYrs;
      return `<tr>
        <td>${i + 1}</td>
        <td class="num">${fmt(woSals[i])}</td>
        <td class="num">${inProgram ? '<span style="color:var(--text-tertiary)">In program</span>' : fmt(wSals[i])}</td>
        <td class="num ${diff >= 0 ? 'pos' : 'neg'}">${fmt(diff)}</td>
        <td class="num ${dcf  >= 0 ? 'pos' : 'neg'}">${fmt(dcf)}</td>
      </tr>`;
    }).join('');
  }
</script>
</body>
</html>
